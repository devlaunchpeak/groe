# =============================================================================
# GROE — Environment Variable Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# =============================================================================

# --- Supabase ---
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — SERVER-SIDE ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT secret for verifying Supabase Edge Function requests server-side.
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# --- WorkOS (Enterprise SSO + Magic Link + SCIM) ---
# Found in: WorkOS Dashboard → API Keys
WORKOS_API_KEY=sk_test_your_workos_api_key
WORKOS_CLIENT_ID=client_your_workos_client_id

# Cookie secret for WorkOS AuthKit session encryption.
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your_32_byte_base64_cookie_password

# OAuth callback URL — must be registered in WorkOS Dashboard → Redirects
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Webhook secret for verifying incoming SCIM provisioning events from WorkOS.
# Found in: WorkOS Dashboard → Webhooks
WORKOS_WEBHOOK_SECRET=your_workos_webhook_secret

# --- Resend (Transactional Email) ---
# Found in: Resend Dashboard → API Keys
RESEND_API_KEY=re_your_resend_api_key

# Sending address — use onboarding@resend.dev for local dev (no verification needed).
# Replace with a verified domain address before going to production.
RESEND_FROM_ADDRESS=onboarding@resend.dev

# --- Video Delivery ---
# OQ-video: replace these with the real vendor vars once Mux or Cloudflare Stream is confirmed.
# Mux example:     MUX_TOKEN_ID / MUX_TOKEN_SECRET
# Cloudflare example: CLOUDFLARE_ACCOUNT_ID / CLOUDFLARE_STREAM_TOKEN
MUX_SECRET_KEY=your_mux_secret_key
MUX_TOKEN_ID=your_mux_token_id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
